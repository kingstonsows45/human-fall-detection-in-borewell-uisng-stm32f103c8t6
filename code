void GSM_SendCommand(char *cmd)
{
    memset(gsm_rx,0,sizeof(gsm_rx));

    HAL_UART_Transmit(&huart1,(uint8_t*)cmd,strlen(cmd),1000);

    HAL_Delay(1000);

    HAL_UART_Receive(&huart1,(uint8_t*)gsm_rx,sizeof(gsm_rx),2000);

    I2C_LCD_Clear(MyI2C_LCD);

    I2C_LCD_SetCursor(MyI2C_LCD,0,0);
    I2C_LCD_WriteString(MyI2C_LCD,"GSM RESP:");

    I2C_LCD_SetCursor(MyI2C_LCD,0,1);
    I2C_LCD_WriteString(MyI2C_LCD,gsm_rx);

    HAL_Delay(2000);
}

void SIM800_SendSMS(char *number, char *message)
{
    char cmd[50];

    GSM_SendCommand("AT\r\n");

    GSM_SendCommand("AT+CMGF=1\r\n");

    sprintf(cmd,"AT+CMGS=\"%s\"\r\n",number);

    HAL_UART_Transmit(&huart1,(uint8_t*)cmd,strlen(cmd),1000);

    HAL_Delay(2000);

    HAL_UART_Transmit(&huart1,(uint8_t*)message,strlen(message),1000);

    uint8_t ctrlz = 26;

    HAL_UART_Transmit(&huart1,&ctrlz,1,1000);

    HAL_Delay(5000);

    HAL_UART_Receive(&huart1,(uint8_t*)gsm_rx,sizeof(gsm_rx),3000);

    I2C_LCD_Clear(MyI2C_LCD);
    I2C_LCD_SetCursor(MyI2C_LCD,0,0);
    I2C_LCD_WriteString(MyI2C_LCD,"SMS RESP:");

    I2C_LCD_SetCursor(MyI2C_LCD,0,1);
    I2C_LCD_WriteString(MyI2C_LCD,gsm_rx);

    HAL_Delay(3000);
}
void SendSensorSMS(float distance)
{
    char sms[160];

    sprintf(sms,
    "BOREWELL ALERT\nTemp:%dC\nHum:%d%%\nDist:%.1fcm\nGas:%lu",
    TEMP,HUM,distance,gas_value);

    SIM800_SendSMS("+919995614045",sms);
}
