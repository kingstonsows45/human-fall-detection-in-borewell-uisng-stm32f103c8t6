  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_ADC1_Init();
  MX_USART1_UART_Init();
  /* USER CODE BEGIN 2 */
  I2C_LCD_Init(MyI2C_LCD);
  I2C_LCD_SetCursor(MyI2C_LCD, 0, 0);
  I2C_LCD_WriteString(MyI2C_LCD, "BOREWELL");
  I2C_LCD_SetCursor(MyI2C_LCD, 0, 1);
  I2C_LCD_WriteString(MyI2C_LCD, "PROJECT");
  char resp[50];

  HAL_UART_Transmit(&huart1,(uint8_t*)"AT\r\n",4,1000);

  HAL_UART_Receive(&huart1,(uint8_t*)resp,50,3000);

  I2C_LCD_Clear(MyI2C_LCD);
  I2C_LCD_SetCursor(MyI2C_LCD,0,0);
  I2C_LCD_WriteString(MyI2C_LCD,resp);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */
	  if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_7) == GPIO_PIN_SET)
	       {
	           float distance = Ultrasonic_Read();
	           HAL_Delay(1000);


	           DHT11_GetData();
	           gas_value = Read_Gas();

	           char line1[16];
	           char line2[16];

	           sprintf(line1,"T:%dC H:%d%%",TEMP,HUM);
	           sprintf(line2,"D:%0.1f G:%lu",distance,gas_value);

	           I2C_LCD_Clear(MyI2C_LCD);

	           I2C_LCD_SetCursor(MyI2C_LCD,0,0);
	           I2C_LCD_WriteString(MyI2C_LCD,line1);

	           I2C_LCD_SetCursor(MyI2C_LCD,0,1);
	           I2C_LCD_WriteString(MyI2C_LCD,line2);
	           if(distance < 30)
	           {
	        	   I2C_LCD_Init(MyI2C_LCD);
	        	   I2C_LCD_SetCursor(MyI2C_LCD, 0, 0);
	        	   I2C_LCD_WriteString(MyI2C_LCD, "FALL DETECTED");
	        	   HAL_Delay(1000);
	        	   I2C_LCD_Clear(MyI2C_LCD);
	               SendSensorSMS(distance);
	           }

	              HAL_Delay(1000);
	       }else{

	           I2C_LCD_Clear(MyI2C_LCD);

	           I2C_LCD_SetCursor(MyI2C_LCD,0,0);
	           I2C_LCD_WriteString(MyI2C_LCD,"safe");
	       }
    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

